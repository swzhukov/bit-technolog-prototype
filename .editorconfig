# EditorConfig: https://editorconfig.org
# Единый стиль для всех редакторов (VSCode, PyCharm, Vim и т.д.)

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false  # Markdown использует trailing пробелы для line breaks

[Makefile]
indent_style = tab
